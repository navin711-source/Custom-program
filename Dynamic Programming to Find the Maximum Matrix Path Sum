#include <stdio.h>

int n, m;

void findmax(int arr[], int row, int dp[][m]) {
    int fmax = dp[row][0], smax = -1;

    for (int j = 1; j < m; j++) {
        if (dp[row][j] > fmax) {
            smax = fmax;
            fmax = dp[row][j];
        } else if (dp[row][j] > smax) {
            smax = dp[row][j];
        }
    }

    arr[0] = fmax;
    arr[1] = smax;
}

int main() {

    scanf("%d %d", & n, & m);

    int mat[n][m], dp[n][m];

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", & mat[i][j]);
            if (i == 0)
                dp[i][j] = mat[i][j];
        }
    }

    int arr[2];

    for (int i = 1; i < n; i++) {
        findmax(arr, i - 1, dp);

        for (int j = 0; j < m; j++) {
            dp[i][j] = mat[i][j] +
                (dp[i - 1][j] == arr[0] ? arr[1] : arr[0]);
        }
    }

    findmax(arr, n - 1, dp);

    printf("%d", arr[0]);

    return 0;
}
