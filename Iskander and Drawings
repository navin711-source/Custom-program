#include <stdio.h>
#include <string.h>

int main() {
    int t;
    scanf("%d", &t);
    while (t--) {
        int n;
        scanf("%d", &n);
        char s[n];
        scanf("%s", s);
        int maxLen=0,curr=0;
        for (int i=0;i<n;i++) {
            if (s[i]=='#') {
                curr++;
                if (curr > maxLen)
                    maxLen = curr;
            } else {
                curr = 0;
            }
        }

        printf("%d\n", (maxLen + 1) / 2);
    }

    return 0;
}
