#include <stdio.h>
#include <stdbool.h>

bool checkValid(int **matrix, int matrixSize, int *matrixColSize)
{
    int i, j, k, n = matrixSize;
    int seen[101];

    // Check rows
    for (i = 0; i < n; i++)
    {
        for (k = 0; k <= n; k++)
            seen[k] = 0;

        for (j = 0; j < n; j++)
        {
            int num = matrix[i][j];

            if (num < 1 || num > n || seen[num])
                return false;

            seen[num] = 1;
        }
    }

    // Check columns
    for (j = 0; j < n; j++)
    {
        for (k = 0; k <= n; k++)
            seen[k] = 0;

        for (i = 0; i < n; i++)
        {
            int num = matrix[i][j];

            if (num < 1 || num > n || seen[num])
                return false;

            seen[num] = 1;
        }
    }

    return true;
}
